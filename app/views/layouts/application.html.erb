<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pulse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pulse">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell <%= "app-shell--signed-in" if logged_in? %>">
      <div class="app-shell__backdrop" aria-hidden="true"></div>

      <% if logged_in? %>
        <aside class="app-sidebar">
          <div class="app-brand">
            <p class="eyebrow">Pulse</p>
            <p class="app-title">Ops Control Room</p>
            <p class="sidebar-copy">Synthetic health, event intake and SLA posture in one surface that reads like an operational desk.</p>
          </div>

          <nav class="app-nav app-nav--stack">
            <%= sidebar_nav_link_to "Dashboard", root_path, active: current_page?(root_path) %>
            <%= sidebar_nav_link_to "Monitors", monitors_path, active: request.path.start_with?(monitors_path) %>
            <%= sidebar_nav_link_to "Integrations", integration_endpoints_path, active: request.path.start_with?(integration_endpoints_path) %>
            <%= sidebar_nav_link_to "Public Status", status_path, active: current_page?(status_path) %>
          </nav>

          <div class="sidebar-note">
            <p class="eyebrow">Workspace</p>
            <strong><%= current_account&.name || "Pulse" %></strong>
            <p><%= current_account&.slug || "workspace" %> is running in monitor-first mode.</p>
          </div>

          <div class="app-sidebar__footer">
            <div class="topbar-chip topbar-chip--sidebar">
              <span class="topbar-chip__dot"></span>
              live surface
            </div>
            <%= button_to "Sign out", logout_path, method: :delete, class: "button button--secondary button--small" %>
          </div>
        </aside>
      <% end %>

      <div class="app-stage <%= "app-stage--public" unless logged_in? %>">
        <% if logged_in? %>
          <header class="app-topbar">
            <div>
              <p class="eyebrow">Operations Desk</p>
              <p class="app-topbar__title"><%= current_account&.slug || "workspace" %></p>
            </div>

            <div class="app-topbar__meta">
              <div class="topbar-chip">
                <span class="topbar-chip__dot"></span>
                live state
              </div>
              <div class="topbar-date"><%= l(Time.zone.now, format: :short) %></div>
            </div>
          </header>
        <% end %>

        <div class="page-frame">
          <% flash.each do |type, message| %>
            <div class="flash flash--<%= type %>"><%= message %></div>
          <% end %>

          <% if flash[:generated_secret].present? %>
            <div class="flash flash--secret">
              <strong>New integration secret</strong>
              <span><%= flash[:generated_secret] %></span>
            </div>
          <% end %>

          <% if flash[:generated_token].present? %>
            <div class="flash flash--secret">
              <strong>Generated heartbeat token</strong>
              <span><%= flash[:generated_token] %></span>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
