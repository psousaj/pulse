<%= form_with model: integration_endpoint, class: "resource-form" do |form| %>
  <% if integration_endpoint.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(integration_endpoint.errors.count, "error") %> blocked this endpoint</h2>
      <ul>
        <% integration_endpoint.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <label class="field">
      <span>Name</span>
      <%= form.text_field :name, required: true %>
    </label>

    <label class="field">
      <span>Provider</span>
      <%= form.select :provider, [["Zabbix", "zabbix"]] %>
    </label>

    <label class="field field--toggle">
      <span>Enabled</span>
      <%= form.check_box :enabled %>
    </label>

    <label class="field field--full">
      <span>Config JSON</span>
      <%= form.text_area :config_json_text, value: config_json_text, rows: 12, class: "code-area", spellcheck: false %>
      <small>Use this for provider-specific request normalization or signature settings.</small>
    </label>
  </div>

  <div class="inline-actions">
    <%= form.submit integration_endpoint.persisted? ? "Save endpoint" : "Create endpoint", class: "button" %>
    <%= link_to "Cancel", integration_endpoint.persisted? ? integration_endpoint_path(integration_endpoint) : integration_endpoints_path, class: "button button--secondary" %>
  </div>
<% end %>