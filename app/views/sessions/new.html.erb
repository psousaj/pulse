<main>
  <h1>Pulse Monitor Login</h1>
  <% if github_oauth_configured? %>
    <p>Sign in with GitHub to access the monitoring dashboard.</p>
    <p>
      <a href="/auth/github">Sign in with GitHub</a>
    </p>
  <% else %>
    <p>GitHub OAuth is not configured in this environment, so dashboard login is currently unavailable.</p>
    <p>Set <strong>GITHUB_CLIENT_ID</strong> and <strong>GITHUB_CLIENT_SECRET</strong> in the environment used by Rails, then restart the app.</p>
  <% end %>
</main>
